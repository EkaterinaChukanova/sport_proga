#include <iostream>
#include <vector>
using namespace std;

bool isPrime(int x) {
    for (int i = 2; i * i <= x; i++)
        if (x % i == 0) return false;
    return x > 1;
}

int main() {
    int t;
    cin >> t;
    
    while (t--) {
        int n;
        cin >> n;
        
        vector<int> p;
        for (int x = 2; p.size() < n; x++)
            if (isPrime(x)) p.push_back(x);
        
        cout << p[0];
        for (int i = 1; i < n - 1; i++)
            cout << ' ' << 1LL * p[i-1] * p[i];
        cout << ' ' << p[n-2] << '\n';
    }
}
