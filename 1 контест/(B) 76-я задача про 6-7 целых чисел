#include <iostream>
#include <algorithm>

int main() {
    int t;
    std::cin >> t;
    
    for (int i = 0; i < t; i++) {
        int arr[7];
        int sum = 0;
        int max_val = -100;
        
        for (int j = 0; j < 7; j++) {
            std::cin >> arr[j];
            sum += arr[j];
            if (arr[j] > max_val) {
                max_val = arr[j];
            }
        }
        
        int answer = -sum + 2 * max_val;
        std::cout << answer << std::endl;
    }
    
    return 0;
}
