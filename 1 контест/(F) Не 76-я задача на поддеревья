#include <iostream>
#include <vector>
#include <string>
#include <algorithm>

using namespace std;

vector<vector<int>> children;
string s;
int balanced_count;

pair<int, int> dfs(int u) {
    int white = 0;
    int black = 0;

    if (s[u - 1] == 'W') {
        white++;
    } else {
        black++;
    }

    for (int v : children[u]) {
        pair<int, int> child_counts = dfs(v);
        white += child_counts.first;
        black += child_counts.second;
    }

    if (white == black) {
        balanced_count++;
    }

    return {white, black};
}

void solve() {
    int n;
    cin >> n;
    
    children.assign(n + 1, vector<int>());
    
    for (int i = 2; i <= n; ++i) {
        int p;
        cin >> p;
        children[p].push_back(i);
    }
    
    cin >> s;
    
    balanced_count = 0;
    
    dfs(1);
    
    cout << balanced_count << "\n";
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int t;
    if (cin >> t) {
        while (t--) {
            solve();
        }
    }
    return 0;
}
