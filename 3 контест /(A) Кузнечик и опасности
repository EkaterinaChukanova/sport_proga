#include <iostream>
using namespace std;

const int MOD = 1000000007;
long long dp[20005];
bool danger[20005];

int main() {
    int n, k, m;
    cin >> n >> k >> m;

    for (int i = 0; i < m; i++) {
        int a;
        cin >> a;
        danger[a] = true;
    }

    dp[0] = 1;
    
    long long current_sum = 1;

    for (int i = 1; i <= n; i++) {
        if (danger[i]) {
            dp[i] = 0;
        } else {
            dp[i] = current_sum;
        }

        current_sum += dp[i];
        
        if (i - k >= 0) {
            current_sum -= dp[i - k];
        }

        current_sum %= MOD;
        if (current_sum < 0) {
            current_sum += MOD;
        }
    }

    cout << dp[n] << endl;
    return 0;
}
