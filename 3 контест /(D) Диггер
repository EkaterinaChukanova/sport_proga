#include <iostream>
#include <algorithm>
using namespace std;

int a[105][105];

int main() {
    int n, m;
    cin >> n >> m;

    for (int i = 1; i <= n; i++)
        for (int j = 1; j <= m; j++)
            cin >> a[i][j];

    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= m; j++) {
            int best_prev = max({a[i-1][j], a[i][j-1], a[i-1][j-1]});
            a[i][j] += best_prev;
        }
    }

    cout << a[n][m] << endl;
    return 0;
}
