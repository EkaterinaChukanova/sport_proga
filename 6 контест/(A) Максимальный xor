#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    int n, k;
    cin >> n >> k;
    vector<long long> a(n);
    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }
    
    long long ans = 0;
    for (int mask = 0; mask < (1 << n); mask++) {
        if (__builtin_popcount(mask) != k) continue;
        
        long long cur = 0;
        for (int i = 0; i < n; i++) {
            if (mask & (1 << i)) {
                cur ^= a[i];
            }
        }
        ans = max(ans, cur);
    }
    
    cout << ans << endl;
    return 0;
}
