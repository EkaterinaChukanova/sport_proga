#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

const int INF = 1e9;

int main() {
    int n;
    cin >> n;
    vector<int> d(n);
    for (int i = 0; i < n; i++) {
        cin >> d[i];
    }
    
    vector<int> dp(1 << n, INF);
    dp[0] = 0;
    for (int mask = 0; mask < (1 << n); mask++) {
        if (dp[mask] == INF) continue;
        
        for (int i = 0; i < n; i++) {
            int new_mask = mask;
            new_mask |= (1 << i);
            new_mask |= (1 << ((i - 2 + n) % n));
            new_mask |= (1 << ((i + 2) % n));
            int damage = 0;
            for (int j = 0; j < n; j++) {
                if (!(new_mask & (1 << j))) {
                    damage += d[j];
                }
            }
            dp[new_mask] = min(dp[new_mask], dp[mask] + damage);
        }
    }
    
    cout << dp[(1 << n) - 1] + 1 << endl;
    
    return 0;
}
