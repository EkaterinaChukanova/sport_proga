#include <iostream>
#include <vector>
using namespace std;

int n, m, k;
vector<int> graph[13];
vector<int> cur_type, best_type;
int best_ans = -1000000000;

void calc(int &prod, int &happy) {
    prod = 0;
    happy = 0;
    
    for (int i = 0; i < n; i++) {
        if (cur_type[i] == 2) happy++;
        if (cur_type[i] == 1) happy--;
    }
    
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < (int)graph[i].size(); j++) {
            int to = graph[i][j];
            if (i > to) continue;
            if (cur_type[i] == 0 && cur_type[to] == 2) happy++;
            if (cur_type[i] == 2 && cur_type[to] == 0) happy++;
            if (cur_type[i] == 1 && cur_type[to] == 2) happy--;
            if (cur_type[i] == 2 && cur_type[to] == 1) happy--;
            if (cur_type[i] == 1 && cur_type[to] == 0) prod++;
            if (cur_type[i] == 0 && cur_type[to] == 1) prod++;
        }
    }
}

void go(int v) {
    if (v == n) {
        int prod, happy;
        calc(prod, happy);
        if (happy >= k && prod > best_ans) {
            best_ans = prod;
            best_type = cur_type;
        }
        return;
    }
    for (int t = 0; t < 3; t++) {
        cur_type[v] = t;
        go(v + 1);
    }
}

int main() {
    cin >> n >> m >> k;
    for (int i = 0; i < m; i++) {
        int a, b;
        cin >> a >> b;
        a--;
        b--;
        graph[a].push_back(b);
        graph[b].push_back(a);
    }
    
    cur_type.resize(n);
    best_type.resize(n);
    go(0);
    cout << best_ans << endl;
    
    for (int t = 0; t < 3; t++) {
        vector<int> now;
        for (int i = 0; i < n; i++) {
            if (best_type[i] == t) {
                now.push_back(i + 1);
            }
        }
        cout << now.size();
        for (int i = 0; i < (int)now.size(); i++) {
            cout << " " << now[i];
        }
        cout << endl;
    }
    
    return 0;
}
