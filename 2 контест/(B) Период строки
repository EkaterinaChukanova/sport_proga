#include <iostream>
#include <vector>
#include <string>
using namespace std;


int main() {
    string s;
    cin >> s;
    int n = s.length();
    for (int i = 1; i <= n; ++i){
        if (n % i != 0) continue;
        string m = s.substr(0, i);
        string repeated;
        for (int j = 0; j < n / i; ++j) {
            repeated += m;
        }
        if (repeated == s) {
            cout << i;
            return 0;
        }
    }
    cout << n;
    return 0;
}
