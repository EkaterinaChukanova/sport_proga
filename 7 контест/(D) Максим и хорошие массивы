#include <iostream>
#include <vector>
#include <map>
using namespace std;

int main() {
    int t;
    cin >> t;
    while (t--) {
        int n, m, k;
        cin >> n >> m >> k;
        vector<int> a(n);
        for (int i = 0; i < n; i++) {
            cin >> a[i];
        }
        vector<int> b(m);
        map<int, int> cnt_b;
        for (int i = 0; i < m; i++) {
            cin >> b[i];
            cnt_b[b[i]]++;
        }
        map<int, int> cnt_a;
        int ans = 0;
        int now = 0;
        for (int i = 0; i < n; i++) {
            cnt_a[a[i]]++;
            if (cnt_b[a[i]] && cnt_a[a[i]] <= cnt_b[a[i]]) {
                now++;
            }
            if (i >= m) {
                int old = a[i - m];
                if (cnt_b[old] && cnt_a[old] <= cnt_b[old]) {
                    now--;
                }
                cnt_a[old]--;
            }
            if (i >= m - 1 && now >= k) {
                ans++;
            }
        }
        cout << ans << '\n';
    }
    
    return 0;
}
