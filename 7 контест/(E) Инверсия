#include <iostream>
#include <vector>
#include <string>
using namespace std;

int main() {
    int t;
    cin >> t;
    while (t--) {
        int n;
        string s;
        cin >> n >> s;
        for (int k = n; k >= 1; k--) {
            vector<int> diff(n + 1, 0);
            int cur = 0;
            bool ok = true;
            for (int i = 0; i < n; i++) {
                cur += diff[i];
                int val = s[i] - '0';
                if (cur % 2 == 1) val = 1 - val;
                if (val == 0) {
                    if (i + k > n) {
                        ok = false;
                        break;
                    }
                    cur++;
                    diff[i + k]--;
                }
            }
            if (ok) {
                cout << k << '\n';
                break;
            }
        }
    }
    
    return 0;
}
