#include <iostream>
#include <vector>
#include <algorithm>
#include <map>
using namespace std;

int main() {
    int t;
    cin >> t;
    while (t--) {
        int n, c, d;
        cin >> n >> c >> d;
        int size = n * n;
        vector<int> b(size);
        for (int i = 0; i < size; i++) {
            cin >> b[i];
        }
        sort(b.begin(), b.end());
        int a11 = b[0];
        vector<int> square(size);
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                square[i * n + j] = a11 + i * c + j * d;
            }
        }
        sort(square.begin(), square.end());
        bool ok = true;
        for (int i = 0; i < size; i++) {
            if (b[i] != square[i]) {
                ok = false;
                break;
            }
        }
        cout << (ok ? "YES" : "NO") << '\n';
    }

    return 0;
}
