#include <iostream>
#include <vector>

using namespace std;

const long long MOD = 1000000007;

int main() {
    int N;
    cin >> N;
    vector<long long> dp(N + 1, 0);
    dp[0] = 1;
    
    for (int i = 1; i <= N; i++) {
        for (int j = N; j >= i; j--) {
            dp[j] = (dp[j] + dp[j - i]) % MOD;
        }
    }
    
    cout << dp[N] << endl;
    
    return 0;
}
