#include <iostream>
#include <vector>

using namespace std;

const long long MOD = 1000000007;

int main() {
    int n, k;
    cin >> n >> k;
    
    vector<long long> dp(n + 1);
    dp[0] = 1;
    
    long long w = 1;
    
    for (int i = 1; i <= n; i++) {
        dp[i] = w;
        
        w = (w + dp[i]) % MOD;
        
        if (i - k >= 0) {
            w = (w - dp[i-k] + MOD) % MOD;
        }
    }
    
    cout << dp[n] % MOD << endl;
    
    return 0;
}
