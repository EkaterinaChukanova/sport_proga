#include <iostream>
using namespace std;

int main() {
    int t;
    cin >> t;

    while (t--) {
        int n, k;
        cin >> n >> k;

        int mx = 0;

        for (int i = 0; i < k; i++) {
            int x;
            cin >> x;
            mx = max(mx, x);
        }

        cout << 2 * (n - mx) - k + 1 << '\n';
    }

    return 0;
}
