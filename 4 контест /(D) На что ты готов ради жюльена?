#include <iostream>
#include <vector>
#include <string>
#include <algorithm>
using namespace std;

int main() {
    int t;
    cin >> t;

    while (t--) {
        int n, m, k;
        cin >> n >> m >> k;

        string a;
        cin >> a;

        string s = "L" + a + "L";

        const int INF = 1e9;
        vector<int> dp(n + 2, INF);
        dp[0] = 0;

        for (int i = 0; i <= n + 1; i++) {
            if (s[i] == 'C' || dp[i] > k) continue;

            if (s[i] == 'L') {
                for (int j = 1; j <= m && i + j <= n + 1; j++) {
                    if (s[i + j] != 'C') {
                        dp[i + j] = min(dp[i + j], dp[i]);
                    }
                }
                if (i + 1 <= n + 1 && s[i + 1] == 'W') {
                    dp[i + 1] = min(dp[i + 1], dp[i] + 1);
                }
            }

            if (s[i] == 'W') {
                if (i + 1 <= n + 1 && s[i + 1] != 'C') {
                    dp[i + 1] = min(dp[i + 1], dp[i] + 1);
                }
            }
        }

        if (dp[n + 1] <= k) {
            cout << "YES\n";
        } else {
            cout << "NO\n";
        }
    }

    return 0;
}
