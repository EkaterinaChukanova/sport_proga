#include <iostream>
using namespace std;

int main() {
    int t;
    cin >> t;
    while (t--) {
        int a, b, c;
        cin >> a >> b >> c;
        int ans = 0;
        for (int i = 0; i <= 5; i++) {
            for (int j = 0; j <= 5 - i; j++) {
                int k = 5 - i - j;
                int na = a + i;
                int nb = b + j;
                int nc = c + k;
                ans = max(ans, na * nb * nc);
            }
        }
        cout << ans << '\n';
    }
    return 0;
}
